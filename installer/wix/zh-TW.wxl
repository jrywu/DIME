          Value="按「變更」開始變更安裝。按「上一步」可檢視或變更安裝設定，或按「取消」結束安裝精靈。" />
  <String Id="VerifyReadyDlgChangeTitle"  Value="{\WixUI_Font_Title}準備好變更 [ProductName]" />
  <String Id="VerifyReadyDlgRepair"       Value="修復(&amp;R)" />
  <String Id="VerifyReadyDlgRepairText"
