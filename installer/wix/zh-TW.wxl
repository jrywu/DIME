<?xml version="1.0" encoding="utf-8"?>
<WixLocalization xmlns="http://wixtoolset.org/schemas/v4/wxl" Culture="zh-TW" Language="1028" Codepage="950">
  <String Id="DowngradeError" Value="偵測到較新版的 DIME，請先解除安裝新版後再安裝。"/>
  <String Id="BundleManagedError" Value="DIME 輸入法目前由 DIME-Universal.exe 安裝程式套件管理，請使用原安裝程式套件進行修復或移除，而非直接執行 .msi 檔案。"/>
  <String Id="x86OnlyWarning" Value="DIME-32bit.msi 僅適用於 32 位元 Windows　64 位元系統請使用 DIME-64bit.msi 或 DIME-Universal.exe 安裝程式。"/>
  <String Id="WelcomeTitle" Value="歡迎使用 DIME 輸入法安裝程式"/>
  <String Id="WelcomeText" Value="本安裝程式將引導您完成 DIME 輸入法的安裝程序。$\n$\n在開始安裝前，建議您關閉所有正在執行的應用程式。$\n$\n按下「安裝」開始安裝。"/>
  <String Id="FinishTitle" Value="安裝完成"/>
  <String Id="FinishText" Value="DIME 輸入法已成功安裝於您的電腦中。"/>
  <String Id="BundleWelcomeTitle" Value="DIME 輸入法安裝程式"/>
  <String Id="InstallButton" Value="安裝"/>
  <String Id="UninstallButton" Value="解除安裝"/>
  <String Id="RepairButton" Value="修復"/>
  <String Id="CancelButton" Value="取消"/>
  <String Id="CloseButton" Value="關閉"/>
  <String Id="ProgressInstalling" Value="正在安裝 DIME 輸入法..."/>
  <String Id="ProgressUninstalling" Value="正在解除安裝 DIME 輸入法..."/>

  <!-- ================================================================
       WixUI dialog strings (zh-TW translations)
       ================================================================ -->

  <!-- Common buttons -->
  <String Id="WixUIBack"   Value="上一步(&amp;B)" />
  <String Id="WixUINext"   Value="下一步(&amp;N)" />
  <String Id="WixUICancel" Value="取消" />
  <String Id="WixUIFinish" Value="完成(&amp;F)" />
  <String Id="WixUIRetry"  Value="重試(&amp;R)" />
  <String Id="WixUIIgnore" Value="略過(&amp;I)" />
  <String Id="WixUIYes"    Value="是(&amp;Y)" />
  <String Id="WixUINo"     Value="否(&amp;N)" />
