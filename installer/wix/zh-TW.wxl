  <String Id="WixUIPrint"  Value="列印(&amp;P)" />

  <!-- WelcomeDlg -->
  <String Id="WelcomeDlg_Title"   Value="[ProductName] [DisplayVersion] 安裝" />
  <String Id="WelcomeDlgTitle"    Value="{\WixUI_Font_Bigger}歡迎使用 [ProductName] [DisplayVersion] 安裝精靈" />
  <String Id="WelcomeDlgDescription"
          Value="本安裝精靈將引導您完成 [ProductName] 的安裝程序。&#xA;&#xA;建議您在繼續前關閉所有其他應用程式，以免安裝過程中發生問題。&#xA;&#xA;按「下一步」繼續，或按「取消」結束安裝精靈。" />
  <String Id="WelcomeUpdateDlgDescriptionUpdate"
          Value="本安裝精靈將更新您電腦上的 [ProductName]。按「下一步」繼續，或按「取消」結束安裝精靈。" />

  <!-- VerifyReadyDlg -->
  <String Id="VerifyReadyDlg_Title"       Value="[ProductName] [DisplayVersion] 安裝" />
