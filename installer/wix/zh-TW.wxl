  <String Id="VerifyReadyDlgInstallText"
          Value="按「安裝」開始安裝。按「上一步」可檢視或變更安裝設定，或按「取消」結束安裝精靈。" />
  <String Id="VerifyReadyDlgInstallTitle" Value="{\WixUI_Font_Title}準備好安裝 [ProductName]" />
